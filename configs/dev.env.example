# configs/dev.env.example — committed to git
# Copy to dev.env and fill in real values
# NEVER commit dev.env itself

# ── GCP ──
PROJECT_ID="your-project-id"
GCS_BUCKET="your-project-id-ml-datasets"
REGION="us-central1"

# ── BigQuery ──
BQ_DEST_DATASET="hackernews_processed"

# ── Data ──
MIN_TEXT_LENGTH="50"
MAX_TEXT_LENGTH="512"
SAMPLE_SIZE="100000"

# ── Model ──
MODEL_NAME="bert-base-uncased"
MAX_SEQ_LENGTH="128"
BATCH_SIZE="32"

# ── Credentials ──
GOOGLE_APPLICATION_CREDENTIALS="./credentials/pipeline-sa-key.json"